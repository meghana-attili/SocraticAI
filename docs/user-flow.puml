@startuml SocraticAI_UserFlow

!theme plain
skinparam backgroundColor #07070f
skinparam defaultFontColor white
skinparam defaultFontSize 13
skinparam defaultFontName "Segoe UI"
skinparam shadowing false
skinparam roundCorner 15
skinparam padding 6
skinparam wrapWidth 160

skinparam activity {
  BackgroundColor #141420
  BorderColor #7c6bff
  FontColor white
  FontSize 13
  DiamondBackgroundColor #1a1a2e
  DiamondBorderColor #f6a430
  DiamondFontColor white
  DiamondFontSize 12
}

skinparam partition {
  BackgroundColor #0e0e1c
  FontColor white
  FontSize 14
  BorderColor #7c6bff
}

skinparam arrow {
  Color #555577
  FontColor #888899
  FontSize 11
}

skinparam note {
  BackgroundColor #1a1025
  BorderColor #a78bfa
  FontColor white
  FontSize 11
}

|#0e0e1c|  Entry  |
start
:User Opens **SocraticAI**;
:NextAuth Login / JWT Session;
:Dashboard with **Collapsible Sidebar**;

fork

  |#0d0d18|  Knowledge Compass  |
  #7c6bff:Enter Subject + Goal + Level;
  :AI Generates Constellation
  Nodes via **Groq**;
  :Review & Edit Nodes;
  :View Constellation Map
  **(Sigma.js v2)**;
  if (All Nodes\nMastered?) then (yes)
    #22d3a0:Shooting Stars
    Celebration;
  else (no)
    :Click Node to Practice;
    :Routes to **Debate** /
    **Hints** / **Rubric**
    with topic pre-filled;
  endif

fork again

  |#0d1218|  Socratic Debate  |
  #22d3a0:Pick Topic;

  split
    :From Compass
    Subjects;
  split again
    :Quick Topics
    (Quantum, Recursion, etc.);
  split again
    :Type Custom
    Topic;
  end split

  :Start Debate Session;

  repeat
    if (Input Method?) then (keyboard)
      :Type Response;
    else (microphone)
      #f6a430:Voice Type
      **(Speech-to-Text)**;
    endif

    :Submit Argument;
    :Groq AI Evaluates
    (correct / gap / concept);
    :AI Responds as **Socrates**;
  repeat while (Continue?) is (yes) not (no)

  :End & Review Summary;
  :Score + Gaps +
  Sound Arguments shown;
  #22d3a0:masteryUpdate
  (isCorrect);

fork again

  |#181208|  Hint System  |
  #f6a430:Enter Question +
  Optional File Upload;
  :AI Generates **3 Hints**
  + **4 Ranking Options**;

  repeat
    :Drag-and-Drop
    Ranking Challenge;
    :Distance-Based
    Scoring (0-100);
    if (Score >= 50?) then (yes)
    else (no)
      :Retry with
      Reshuffled Options;
    endif
  repeat while (Score < 50?) is (yes) not (no)

  #22d3a0:Unlock Hint 1;
  :Progressive Unlock:
  Hint 2, then Hint 3 / Full Solution;

  if (Learning Mode?) then (yes)
    :Show correct order
    + explanations;
  else (no)
    :Store score silently
    **(Exam Mode)**;
  endif
  #f6a430:masteryUpdate
  (ranking_score);

fork again

  |#0d120e|  Rubric Feedback  |
  #a78bfa:Select Rubric Type
  or Custom;
  :Paste / Upload
  Submission;
  :AI Grades via
  Rubric Criteria;
  :Show Scores per Criterion
  + Grade + Strengths
  + Improvements;
  #a78bfa:masteryUpdate
  (rubric_score);

fork again

  |#120d18|  Master Tracker  |
  :View **General Tab**
  (all subjects);
  :Stats: Overall Confidence,
  Topics, Exchanges, Weak Areas;
  :Source Breakdown:
  Debate / Hints / Rubric counts;
  :Subject Breakdown
  with Progress Bars;
  :Click Subject Tab
  for Subtopic Detail;
  :View Constellation Button;

fork again

  |#181210|  Integrity Mode  |
  #f6a430:Toggle **Learning Mode**
  or **Exam Mode**;
  :Affects **Hint System** +
  **Debate** behavior globally;

end fork

|#0e0e1c|  Classification Engine  |

#22d3a0:masteryUpdate Gateway;

:Tier 1: **Exact Match**;

if (Match found?) then (yes)
  :Map to Canonical
  Constellation Node;
else (no)
  :Tier 2: **Token Similarity**;
  if (Match found?) then (yes)
    :Map to Canonical
    Constellation Node;
  else (no)
    :Tier 3: **Async LLM**
    Reclassification;
    :Map to Canonical
    Constellation Node;
  endif
endif

:Update **Local Mastery Store**;
:Master Tracker reflects
updated confidence;

stop

@enduml
