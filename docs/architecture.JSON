{
    "architecture": {
        "name": "Knowledge Compass - Production Architecture",
        "theme": "light",
        "style": {
            "background": "#F8F9FB",
            "boxFill": "#FFFFFF",
            "borderColor": "#E2E8F0",
            "arrowColor": "#94A3B8",
            "textPrimary": "#1E293B",
            "textSecondary": "#64748B",
            "borderRadius": "8px",
            "spacing": "generous"
        },
        "layers": [
            {
                "id": "layer-1",
                "name": "CLIENT LAYER",
                "position": "top",
                "alignment": "center",
                "width": "full",
                "components": [
                    {
                        "id": "client-main",
                        "type": "container",
                        "name": "Client Application",
                        "tech": "Next.js 14 (App Router, TypeScript)",
                        "features": [
                            "Knowledge Compass (Sigma.js)",
                            "Socratic Debate",
                            "Hint + Ranking Engine",
                            "Master Tracker",
                            "InsightCanvas (NEW)",
                            "Integrity / Exam Mode"
                        ],
                        "style": {
                            "border": "light-grey",
                            "background": "white",
                            "corners": "rounded"
                        }
                    },
                    {
                        "id": "auth-layer",
                        "type": "sub-container",
                        "name": "NextAuth (JWT Session)",
                        "position": "below-client-main",
                        "connections": {
                            "to": [
                                "api-gateway"
                            ],
                            "direction": "down",
                            "type": "arrow"
                        }
                    }
                ]
            },
            {
                "id": "layer-2",
                "name": "API GATEWAY LAYER",
                "position": "center",
                "alignment": "center",
                "components": [
                    {
                        "id": "api-gateway",
                        "type": "container",
                        "name": "API GATEWAY",
                        "tech": "Next.js Route Handlers",
                        "endpoints": [
                            "/api/auth",
                            "/api/debate",
                            "/api/ranking",
                            "/api/hint",
                            "/api/mastery",
                            "/api/graph",
                            "/api/upload",
                            "/api/selection/analyze",
                            "/api/manim/render"
                        ],
                        "connections": {
                            "from": [
                                "auth-layer"
                            ],
                            "to": [
                                "orchestrator"
                            ],
                            "direction": "down",
                            "type": "arrow"
                        }
                    }
                ]
            },
            {
                "id": "layer-3",
                "name": "ORCHESTRATION LAYER",
                "subtitle": "Control Plane",
                "position": "center",
                "alignment": "center",
                "width": "wide",
                "components": [
                    {
                        "id": "orchestrator",
                        "type": "container",
                        "name": "Learning Orchestrator (Deterministic Control Plane)",
                        "layout": "4-column-grid",
                        "pipelines": {
                            "column-1": [
                                {
                                    "name": "debatePipeline()",
                                    "connects_to": [
                                        "classification-engine",
                                        "knowledge-scoped-retrieval",
                                        "argument-parsing",
                                        "debate-generation",
                                        "debate-validator",
                                        "mastery-aggregation"
                                    ]
                                }
                            ],
                            "column-2": [
                                {
                                    "name": "rankingPipeline()",
                                    "connects_to": [
                                        "ranking-evaluation",
                                        "misconception-detection",
                                        "pedagogy-agent",
                                        "mastery-aggregation"
                                    ]
                                },
                                {
                                    "name": "hintPipeline()",
                                    "connects_to": [
                                        "knowledge-scoped-retrieval",
                                        "pedagogy-agent"
                                    ]
                                }
                            ],
                            "column-3": [
                                {
                                    "name": "multimodalPipeline()",
                                    "connects_to": [
                                        "multimodal-processing",
                                        "ocr-engine",
                                        "equation-extractor",
                                        "vision-classification"
                                    ]
                                },
                                {
                                    "name": "insightCanvasPipeline()",
                                    "connects_to": [
                                        "ocr-engine",
                                        "vision-classification",
                                        "classification-engine",
                                        "equation-extractor",
                                        "manim-generator",
                                        "knowledge-scoped-retrieval"
                                    ]
                                }
                            ],
                            "column-4": [
                                {
                                    "name": "masteryUpdatePipeline()",
                                    "connects_to": [
                                        "mastery-aggregation",
                                        "adaptive-difficulty"
                                    ]
                                }
                            ]
                        },
                        "core_systems": {
                            "type": "sub-container",
                            "position": "bottom-inside",
                            "components": [
                                "Parallel Execution Manager",
                                "Validation Gate",
                                "Regeneration Guard",
                                "State Commit Manager"
                            ]
                        },
                        "connections": {
                            "from": [
                                "api-gateway"
                            ],
                            "to": [
                                "intelligence-layer"
                            ],
                            "direction": "down",
                            "type": "arrow"
                        }
                    }
                ]
            },
            {
                "id": "layer-4",
                "name": "INTELLIGENCE LAYER",
                "subtitle": "Stateless Agent Modules",
                "position": "center",
                "alignment": "center",
                "layout": "grid",
                "grid": {
                    "columns": 3,
                    "rows": 5,
                    "spacing": "even"
                },
                "components": [
                    {
                        "row": 1,
                        "agents": [
                            {
                                "id": "classification-engine",
                                "name": "Classification Engine",
                                "type": "agent-box"
                            },
                            {
                                "id": "knowledge-scoped-retrieval",
                                "name": "Knowledge-Scoped Retrieval Agent",
                                "type": "agent-box"
                            },
                            {
                                "id": "multimodal-processing",
                                "name": "Multimodal Processing Agent",
                                "type": "agent-box"
                            }
                        ]
                    },
                    {
                        "row": 2,
                        "agents": [
                            {
                                "id": "argument-parsing",
                                "name": "Argument Parsing Agent",
                                "type": "agent-box"
                            },
                            {
                                "id": "debate-generation",
                                "name": "Debate Generation Agent",
                                "type": "agent-box"
                            },
                            {
                                "id": "debate-validator",
                                "name": "Debate Validator Agent",
                                "type": "agent-box"
                            }
                        ]
                    },
                    {
                        "row": 3,
                        "agents": [
                            {
                                "id": "ranking-evaluation",
                                "name": "Ranking Evaluation Agent",
                                "type": "agent-box"
                            },
                            {
                                "id": "misconception-detection",
                                "name": "Misconception Detection Agent",
                                "type": "agent-box"
                            },
                            {
                                "id": "pedagogy-agent",
                                "name": "Pedagogy Agent",
                                "type": "agent-box"
                            }
                        ]
                    },
                    {
                        "row": 4,
                        "agents": [
                            {
                                "id": "mastery-aggregation",
                                "name": "Mastery Aggregation Agent",
                                "type": "agent-box"
                            },
                            {
                                "id": "adaptive-difficulty",
                                "name": "Adaptive Difficulty Engine",
                                "type": "agent-box"
                            },
                            {
                                "id": "manim-generator",
                                "name": "Manim Script Generator",
                                "type": "agent-box"
                            }
                        ]
                    },
                    {
                        "row": 5,
                        "agents": [
                            {
                                "id": "ocr-engine",
                                "name": "OCR Engine",
                                "type": "agent-box"
                            },
                            {
                                "id": "equation-extractor",
                                "name": "Equation → LaTeX Extractor",
                                "type": "agent-box"
                            },
                            {
                                "id": "vision-classification",
                                "name": "Vision Classification Model",
                                "type": "agent-box"
                            }
                        ]
                    }
                ],
                "connections": {
                    "from": [
                        "orchestrator"
                    ],
                    "to": [
                        "data-model-layer"
                    ],
                    "direction": "down",
                    "type": "arrow",
                    "note": "Each pipeline connects only to relevant agents (thin arrows)"
                }
            },
            {
                "id": "layer-5",
                "name": "DATA + MODEL LAYER",
                "position": "center",
                "alignment": "center",
                "layout": "3-column-split",
                "components": [
                    {
                        "column": "left",
                        "name": "Databases",
                        "databases": [
                            {
                                "id": "mongodb",
                                "name": "MongoDB Cluster",
                                "type": "database",
                                "status": "future-migration",
                                "collections": [
                                    "users",
                                    "canonical_nodes",
                                    "misconceptions",
                                    "user_node_mastery",
                                    "debate_history",
                                    "ranking_attempts",
                                    "hint_usage",
                                    "documents",
                                    "document_selections",
                                    "node_embeddings (vector index)"
                                ],
                                "note": "Currently PostgreSQL - migration planned"
                            },
                            {
                                "id": "postgresql",
                                "name": "PostgreSQL",
                                "type": "database",
                                "status": "current",
                                "tables": [
                                    "users",
                                    "canonical_nodes",
                                    "misconceptions",
                                    "user_node_mastery",
                                    "debate_history",
                                    "ranking_attempts",
                                    "hint_usage",
                                    "documents",
                                    "document_selections",
                                    "node_embeddings (pgvector)"
                                ],
                                "note": "Active production database"
                            },
                            {
                                "id": "neo4j",
                                "name": "Neo4j Graph DB",
                                "type": "graph-database",
                                "relationships": [
                                    "prerequisites",
                                    "dependencies",
                                    "learning paths",
                                    "constellation topology"
                                ]
                            },
                            {
                                "id": "redis",
                                "name": "Redis",
                                "type": "cache",
                                "use_cases": [
                                    "session cache",
                                    "rate limiting",
                                    "LLM deduplication",
                                    "regeneration lock"
                                ]
                            }
                        ]
                    },
                    {
                        "column": "middle",
                        "name": "Model Providers",
                        "models": [
                            {
                                "id": "groq-llama",
                                "name": "Groq LLaMA 3 70B",
                                "type": "llm",
                                "use_cases": [
                                    "Generation",
                                    "Reclassification",
                                    "Debate"
                                ]
                            },
                            {
                                "id": "embedding-model",
                                "name": "Embedding Model",
                                "type": "embedding",
                                "use_cases": [
                                    "Vector similarity search"
                                ]
                            },
                            {
                                "id": "vision-model",
                                "name": "Vision Model",
                                "type": "multimodal",
                                "use_cases": [
                                    "Multimodal understanding"
                                ]
                            }
                        ]
                    },
                    {
                        "column": "right",
                        "name": "InsightCanvas Compute",
                        "services": [
                            {
                                "id": "manim-service",
                                "name": "Manim Rendering Service",
                                "type": "microservice",
                                "tech": "Python Container",
                                "flow": [
                                    "LaTeX → Manim Script → Render Video → Return URL"
                                ],
                                "connections": {
                                    "from": [
                                        "equation-extractor",
                                        "manim-generator"
                                    ],
                                    "type": "dedicated-pipeline"
                                }
                            }
                        ]
                    }
                ]
            },
            {
                "id": "layer-6",
                "name": "INFRASTRUCTURE / DEPLOYMENT LAYER",
                "position": "bottom",
                "alignment": "center",
                "style": {
                    "background": "#F1F5F9",
                    "border": "#CBD5E1"
                },
                "components": [
                    {
                        "id": "cdn-edge",
                        "type": "service-cluster",
                        "layout": "vertical-flow",
                        "flow": [
                            {
                                "name": "CDN / Edge",
                                "type": "cdn"
                            },
                            {
                                "name": "Next.js Web Server (Docker)",
                                "type": "web-server"
                            },
                            {
                                "name": "Orchestrator Service (Docker)",
                                "type": "orchestrator-service"
                            }
                        ]
                    },
                    {
                        "id": "backing-services",
                        "type": "service-row",
                        "layout": "horizontal",
                        "services": [
                            {
                                "name": "MongoDB Atlas",
                                "type": "managed-db",
                                "status": "future"
                            },
                            {
                                "name": "PostgreSQL",
                                "type": "managed-db",
                                "status": "current"
                            },
                            {
                                "name": "Neo4j Aura",
                                "type": "managed-graph-db"
                            },
                            {
                                "name": "Redis",
                                "type": "managed-cache"
                            },
                            {
                                "name": "Manim Container",
                                "type": "containerized-service"
                            },
                            {
                                "name": "Groq API",
                                "type": "external-api"
                            }
                        ]
                    },
                    {
                        "id": "infrastructure-notes",
                        "type": "metadata",
                        "details": [
                            "Ubuntu 24.04",
                            "Dockerized Services",
                            "Stateless API Scaling",
                            "CI/CD via GitHub Actions"
                        ]
                    }
                ]
            }
        ],
        "data_flows": [
            {
                "name": "Debate Flow",
                "path": [
                    "User",
                    "API Gateway",
                    "debatePipeline",
                    "Classification Engine",
                    "Knowledge-Scoped Retrieval",
                    "Argument Parsing",
                    "Debate Generation",
                    "Debate Validator",
                    "Mastery Aggregation",
                    "PostgreSQL/MongoDB"
                ],
                "color": "#3B82F6"
            },
            {
                "name": "Ranking Flow",
                "path": [
                    "User",
                    "API Gateway",
                    "rankingPipeline",
                    "Ranking Evaluation",
                    "Misconception Detection",
                    "Pedagogy Agent",
                    "Mastery Aggregation",
                    "PostgreSQL/MongoDB"
                ],
                "color": "#8B5CF6"
            },
            {
                "name": "InsightCanvas Flow",
                "path": [
                    "User Upload",
                    "/api/upload",
                    "User Selection",
                    "/api/selection/analyze",
                    "OCR / Vision Classification",
                    "If equation: LaTeX Extraction",
                    "Manim Script Generation",
                    "Manim Rendering Service",
                    "Return Animation URL + Explanation"
                ],
                "color": "#10B981"
            },
            {
                "name": "Mastery Update Flow",
                "path": [
                    "System Confidence Score",
                    "Mastery Aggregation Agent",
                    "Adaptive Difficulty Engine",
                    "PostgreSQL/MongoDB user_node_mastery"
                ],
                "color": "#F59E0B",
                "note": "Always updated from system confidence, never manual"
            }
        ],
        "production_grade_features": [
            "Deterministic orchestration",
            "Node-scoped RAG",
            "Agent modularity",
            "Multimodal separation",
            "Dedicated rendering microservice",
            "Graph + vector hybrid retrieval",
            "Redis performance layer",
            "Stateless horizontal scaling",
            "Clear validation boundary",
            "Dual database support (PostgreSQL current, MongoDB future)"
        ],
        "metadata": {
            "version": "1.0.0",
            "created": "2025-01-15",
            "author": "Knowledge Compass Engineering Team",
            "status": "Production-Ready Architecture",
            "database_status": {
                "current": "PostgreSQL with pgvector",
                "planned": "MongoDB with vector search",
                "transition": "Gradual migration planned"
            }
        }
    }
}